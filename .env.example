# Public site origin (no trailing slash). Used for canonical URLs, Open Graph, and JSON-LD.
# Production: https://www.3dboxstudio.com
NEXT_PUBLIC_SITE_ORIGIN=https://www.3dboxstudio.com

# Bump when replacing public/images/featured-image.jpg so social crawlers fetch the new asset.
NEXT_PUBLIC_OG_IMAGE_VERSION=2

# Meta app ID for fb:app_id (Facebook Sharing Debugger / Open Graph).
NEXT_PUBLIC_FACEBOOK_APP_ID=

# AWS S3 — share image storage (server-only)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=3dboxstudio
# Optional CloudFront or custom CDN base (no trailing slash). Falls back to virtual-hosted S3 URL.
AWS_S3_PUBLIC_BASE_URL=
# Object key prefix for shared designs (default: shares/)
AWS_S3_SHARE_PREFIX=shares/

# Neon Postgres — pooled connection string (server-only)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Share link settings (server-only)
SHARE_TTL_DAYS=90
SHARE_MAX_PAYLOAD_BYTES=4500000

# Resend — transactional email for account verification (server-only)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# From address for verification emails. Must be on a domain verified in Resend.
# For local testing you can use Resend's shared sender:
EMAIL_FROM=3D Box Studio <onboarding@resend.dev>

# Admin panel password (server-only). Change in production.
ADMIN_PASSWORD=3dboxstudio-admin
