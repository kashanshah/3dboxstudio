# Public site origin (no trailing slash). Used for canonical URLs, Open Graph, and JSON-LD.
# Production: https://www.3dboxstudio.com
VITE_SITE_ORIGIN=https://www.3dboxstudio.com

# Bump when replacing public/images/featured-image.jpg so social crawlers fetch the new asset.
VITE_OG_IMAGE_VERSION=2

# Meta app ID for fb:app_id (Facebook Sharing Debugger / Open Graph).
# Create an app at https://developers.facebook.com/ and paste its App ID here.
VITE_FACEBOOK_APP_ID=
